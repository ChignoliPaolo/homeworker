# ---------------------------------------------------------------------------
# HomeWorker environment configuration
# Copy this file to `.env` and fill in your values.
#
# NOTE: Only variables prefixed with EXPO_PUBLIC_ are exposed to the app bundle
# (they are inlined at build time by Expo). NEVER put a raw OpenAI / Gemini
# provider key here — it would ship inside the app and could be extracted.
# Instead, point EXPO_PUBLIC_VISION_API_URL at YOUR backend proxy that holds
# the secret key server-side.
# ---------------------------------------------------------------------------

# Keep mock mode on to run the full UX with no backend/API key.
EXPO_PUBLIC_USE_MOCK=true

# Your backend proxy endpoint (recommended over calling a provider directly).
EXPO_PUBLIC_VISION_API_URL=https://your-backend.example.com/api/solve

# Optional session/user token for YOUR backend (not a provider key).
EXPO_PUBLIC_VISION_API_KEY=

# Model identifier forwarded to the backend (e.g. gpt-4o, gemini-1.5-pro).
EXPO_PUBLIC_VISION_MODEL=gpt-4o

# Abort a request after this many milliseconds.
EXPO_PUBLIC_REQUEST_TIMEOUT_MS=45000
